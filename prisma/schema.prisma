  @@index([dataOrcamento])
  @@index([etapaId])
  @@index([vendedorId])
  @@map("fato_pedido")
}

model FatoPedidoParcela {
  odooId             Int       @id @map("odoo_id")
  pedidoId           Int?      @map("pedido_id")
  numero             String?
  participanteId     Int?      @map("participante_id")
  participanteNome   String?   @map("participante_nome")
  dataVencimento     DateTime? @map("data_vencimento")
  valor              Decimal   @default(0) @db.Decimal(18, 2)
  vrJuros            Decimal   @default(0) @db.Decimal(18, 2) @map("vr_juros")
  vrMulta            Decimal   @default(0) @db.Decimal(18, 2) @map("vr_multa")
  vrDesconto         Decimal   @default(0) @db.Decimal(18, 2) @map("vr_desconto")
  vrDocumento        Decimal   @default(0) @db.Decimal(18, 2) @map("vr_documento")
  formaPagamentoNome String?   @map("forma_pagamento_nome")
  parcelaFaturada    Boolean   @default(false) @map("parcela_faturada")
  finanLancamentoId  Int?      @map("finan_lancamento_id")
  atualizadoEm       DateTime  @default(now()) @map("atualizado_em")

  @@index([dataVencimento])
  @@index([pedidoId])
  @@map("fato_pedido_parcela")
}

model FatoNotaFiscal {
  odooId               Int       @id @map("odoo_id")
  numero               String?
  serie                String?
  modelo               String?
  entradaSaida         String?   @map("entrada_saida")
  tipoMovimento        String    @default("outro") @map("tipo_movimento")
  situacaoNfe          String?   @map("situacao_nfe")
  finalidadeNfe        String?   @map("finalidade_nfe")
  chave                String?
  participanteId       Int?      @map("participante_id")
  participanteNome     String?   @map("participante_nome")
  naturezaOperacaoId   Int?      @map("natureza_operacao_id")
  naturezaOperacaoNome String?   @map("natureza_operacao_nome")
  empresaId            Int?      @map("empresa_id")
  empresaNome          String?   @map("empresa_nome")
  dataEmissao          DateTime? @map("data_emissao")
  dataEntradaSaida     DateTime? @map("data_entrada_saida")
  dataAutorizacao      DateTime? @map("data_autorizacao")
  vrNf                 Decimal   @default(0) @db.Decimal(18, 2) @map("vr_nf")
  vrProdutos           Decimal   @default(0) @db.Decimal(18, 2) @map("vr_produtos")
  vrFatura             Decimal   @default(0) @db.Decimal(18, 2) @map("vr_fatura")
  vrIbpt               Decimal   @default(0) @db.Decimal(18, 2) @map("vr_ibpt")
  vrIcmsProprio        Decimal   @default(0) @db.Decimal(18, 2) @map("vr_icms_proprio")
  vrDesconto           Decimal   @default(0) @db.Decimal(18, 2) @map("vr_desconto")
  atualizadoEm         DateTime  @default(now()) @map("atualizado_em")

  @@index([dataEmissao])
  @@index([entradaSaida])
  @@index([situacaoNfe])
  @@map("fato_nota_fiscal")
}

model FatoNotaFiscalItem {
  odooId          Int       @id @map("odoo_id")
  documentoId     Int?      @map("documento_id")
  produtoId       Int?      @map("produto_id")
  produtoNome     String?   @map("produto_nome")
  cfopId          Int?      @map("cfop_id")
  cfopNome        String?   @map("cfop_nome")
  quantidade      Decimal   @default(0) @db.Decimal(18, 2)
  vrUnitario      Decimal   @default(0) @db.Decimal(18, 2) @map("vr_unitario")
  vrProdutos      Decimal   @default(0) @db.Decimal(18, 2) @map("vr_produtos")
  vrNf            Decimal   @default(0) @db.Decimal(18, 2) @map("vr_nf")
  vrIcmsProprio   Decimal   @default(0) @db.Decimal(18, 2) @map("vr_icms_proprio")
  vrPisProprio    Decimal   @default(0) @db.Decimal(18, 2) @map("vr_pis_proprio")
  vrCofinsProprio Decimal   @default(0) @db.Decimal(18, 2) @map("vr_cofins_proprio")
  // Desnormalizados da nota-mãe (achado N8) — filtragem por período sem join.
  dataEmissao     DateTime? @map("data_emissao")
  entradaSaida    String?   @map("entrada_saida")
  atualizadoEm    DateTime  @default(now()) @map("atualizado_em")

  @@index([documentoId])
  @@index([produtoId])
  @@index([dataEmissao])
  @@map("fato_nota_fiscal_item")
}

model FatoParceiro {
  odooId       Int      @id @map("odoo_id")
  nome         String?
  nomeCompleto String?  @map("nome_completo")
  documento    String?
  ehCliente    Boolean  @default(false) @map("eh_cliente")
  ehFornecedor Boolean  @default(false) @map("eh_fornecedor")
  ehEmpresa    Boolean  @default(false) @map("eh_empresa")
  cidade       String?
  uf           String?
  pais         String?
  cep          String?
  email        String?
  telefone     String?
  ativo        Boolean  @default(true)
  atualizadoEm DateTime @default(now()) @map("atualizado_em")

  @@index([uf])
  @@index([ehCliente])
  @@index([ehFornecedor])
  @@map("fato_parceiro")
}

// Colunas DEFINITIVAS — fonte de verdade: discovery O.2/O.3
// (docs/superpowers/research/2026-05-18-f4-discovery-pre-schema.md).
model FatoContaContabil {
  odooId              Int      @id @map("odoo_id")
  codigo              String
  nome                String
  tipo                String
  nivel               Int?
  natureza            String?
  contaPaiId          Int?     @map("conta_pai_id")
  contaPaiNome        String?  @map("conta_pai_nome")
  parentPath          String?  @map("parent_path")
  caracteristicaSaldo String?  @map("caracteristica_saldo")
  ehRedutora          Boolean  @default(false) @map("eh_redutora")
  atualizadoEm        DateTime @default(now()) @map("atualizado_em")

  @@index([tipo])
  @@index([natureza])
  @@index([contaPaiId])
  @@map("fato_conta_contabil")
}

// ─── F4 — Logs e feature requests do MCP ─────────────────────────────────────

/// Log de auditoria de chamadas ao MCP semântico.
model McpAuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  tool       String
  params     Json
  outcome    String
  rowCount   Int?     @map("row_count")
  durationMs Int?     @map("duration_ms")
  criadoEm   DateTime @default(now()) @map("criado_em")

  @@index([userId, criadoEm])
  @@map("mcp_audit_log")
}

/// Registro de perguntas fora do catálogo (Caminho 3a — gap logging).
model FeatureRequest {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  perguntaResumo String   @map("pergunta_resumo")
  dominio        String?
  criadoEm       DateTime @default(now()) @map("criado_em")

  @@map("feature_requests")
}

// ─── F5 — Agente de IA + WhatsApp + Integrações ──────────────────────────────

/// Número de WhatsApp vinculado a um usuário da plataforma (N por usuário).
model UserWhatsappNumber {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  phoneE164  String    @unique @map("phone_e164")
  label      String?
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("user_whatsapp_numbers")
}

/// Conversa de agente (WhatsApp, in-app ou playground).
/// Agrupamento: WhatsApp → automático (< 24h); in-app/playground → explícito.
model Conversation {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @map("user_id") @db.Uuid
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   AgentChannel
  title     String?
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  messages  Message[]

  @@index([userId, updatedAt])
  @@map("conversations")
}

/// Mensagem de conversa (user, assistant ou tool).
model Message {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String
  toolCalls      Json?        @map("tool_calls")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([conversationId, createdAt])
  @@map("messages")
}

/// Credencial de API de LLM — chave cifrada com AES-256.
model LlmCredential {
  id              String    @id @default(uuid()) @db.Uuid
  provider        String
  label           String
  encryptedApiKey String    @map("encrypted_api_key")
  last4           String
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  createdById     String?   @map("created_by_id") @db.Uuid
  configs         LlmConfig[]

  /// Saldo/crédito da conta do provedor para esta chave.
  /// balanceStatus: "ok" (valor real), "unavailable" (provedor sem API de saldo),
  /// "error" (consulta falhou). balanceUsd nulo quando status != "ok".
  balanceUsd       Decimal?  @map("balance_usd") @db.Decimal(14, 4)
  balanceCurrency  String?   @map("balance_currency")
  balanceStatus    String?   @map("balance_status")
  balanceCheckedAt DateTime? @map("balance_checked_at")

  @@unique([provider, label])
  @@index([provider, updatedAt(sort: Desc)])
  @@map("llm_credentials")
}

/// Configuração LLM ativa (provider + model + credencial).
/// Ativar é transacional: desativa todas e ativa a escolhida.
model LlmConfig {
  id           String         @id @default(uuid()) @db.Uuid
  provider     String
  model        String
  credentialId String?        @map("credential_id") @db.Uuid
  credential   LlmCredential? @relation(fields: [credentialId], references: [id])
  isActive     Boolean        @default(false) @map("is_active")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@map("llm_configs")
}

/// Registro de uso de LLM por iteração do loop de tool calling.
/// costUsd = null quando costKnown = false (modelo sem preço no catálogo).
/// costBrl calculado com cotação versionada; rateStale=true se cotação falhou.
model LlmUsage {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String?  @map("conversation_id") @db.Uuid
  provider       String
  model          String
  tokensInput    Int      @map("tokens_input")
  tokensOutput   Int      @map("tokens_output")
  costUsd        Decimal? @map("cost_usd") @db.Decimal(12, 6)
  costKnown      Boolean  @default(true) @map("cost_known")
  costBrl        Decimal? @map("cost_brl") @db.Decimal(14, 6)
  usdToBrlRate   Decimal? @map("usd_to_brl_rate") @db.Decimal(10, 4)
  rateSpread     Decimal? @map("rate_spread") @db.Decimal(6, 4)
  rateStale      Boolean  @default(false) @map("rate_stale")
  promptChars    Int?     @map("prompt_chars")
  responseChars  Int?     @map("response_chars")
  durationMs     Int?     @map("duration_ms")
  errorMessage   String?  @map("error_message")
  isPlayground   Boolean  @default(false) @map("is_playground")
  userId         String?  @map("user_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([provider, model, createdAt])
  @@map("llm_usage")
}

/// Configuração do agente — singleton (id="global").
model AgentSettings {
  id                String   @id @default("global")
  identityBase      String?  @map("identity_base")
  personality       String   @default("")
  tone              String   @default("")
  guardrails        Json     @default("[]")
  terminology       Json     @default("{}")
  advancedOverride  String?  @map("advanced_override")
  suggestionsEnabled Boolean @default(true) @map("suggestions_enabled")

  /// Exibição da bolha flutuante do Agente Nex nas páginas autenticadas.
  bubbleEnabled     Boolean  @default(true) @map("bubble_enabled")

  /// Checkpoints de 3 estados (OFF/PLAYGROUND/PRODUCTION).
  audioCheckpoint   FeatureCheckpoint @default(OFF) @map("audio_checkpoint")
  imageCheckpoint   FeatureCheckpoint @default(OFF) @map("image_checkpoint")
  kbCheckpoint      FeatureCheckpoint @default(PRODUCTION) @map("kb_checkpoint")

  /// Modelo dedicado de transcrição de áudio (independente do modelo de produção).
  audioProvider     String?  @map("audio_provider")
  audioModel        String?  @map("audio_model")

  /// Modelo dedicado de entendimento de imagem (independente do modelo de produção).
  imageProvider     String?  @map("image_provider")
  imageModel        String?  @map("image_model")

  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("agent_settings")
}

/// Documento da base de conhecimento do agente.
/// A coluna embedding vector(1536) é adicionada via SQL raw na migration (pgvector, onda 7).
model KbDocument {
  id            String            @id @default(uuid()) @db.Uuid
  name          String
  kind          KbKind            @default(TXT)
  sourceUrl     String?           @map("source_url")
  extractedText String            @map("extracted_text")
  charCount     Int               @map("char_count")
  /// Checkpoint do documento: OFF, PLAYGROUND ou PRODUCTION.
  checkpoint    FeatureCheckpoint @default(PRODUCTION)
  createdAt     DateTime          @default(now()) @map("created_at")

  @@map("kb_documents")
}

/// Sessão persistente do playground do Agente Nex.
/// Cada sessão tem provedor/modelo próprios, snapshot de prompt editável
/// e histórico de mensagens com custo acumulado. Independente da produção.
model PlaygroundSession {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String?
  provider       String
  model          String
  /// Snapshot do prompt da sessão: { identityBase, personality, tone, guardrails }.
  /// Inicia como cópia da produção; editável sem afetar produção.
  promptSnapshot Json     @map("prompt_snapshot")
  costUsd        Decimal  @default(0) @map("cost_usd") @db.Decimal(14, 6)
  costBrl        Decimal  @default(0) @map("cost_brl") @db.Decimal(14, 6)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  /// Preenchido quando a sessão é arquivada ("Nova sessão").
  archivedAt     DateTime? @map("archived_at")

  messages       PlaygroundMessage[]

  @@index([userId, updatedAt(sort: Desc)])
  @@map("playground_sessions")
}

/// Mensagem de uma sessão de playground.
model PlaygroundMessage {
  id        String            @id @default(uuid()) @db.Uuid
  sessionId String            @map("session_id") @db.Uuid
  session   PlaygroundSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      MessageRole
  content   String
  toolCalls Json?             @map("tool_calls")
  costUsd   Decimal?          @map("cost_usd") @db.Decimal(12, 6)
  createdAt DateTime          @default(now()) @map("created_at")

  @@index([sessionId, createdAt])
  @@map("playground_messages")
}

/// Canal WhatsApp — singleton (id="global") com credenciais Meta + modo de resposta.
model WhatsappChannel {
  id                String               @id @default("global")
  encryptedApiToken String?              @map("encrypted_api_token")
  businessAccountId String?              @map("business_account_id")
  phoneNumberId     String?              @map("phone_number_id")
  responseMode      WhatsappResponseMode @default(direct)
  enabled           Boolean              @default(false)
  updatedAt         DateTime             @updatedAt @map("updated_at")

  @@map("whatsapp_channel")
}

/// Webhook configurado (inbound = receptor; outbound = n8n callback).
model WhatsappWebhook {
  id        String           @id @default(uuid()) @db.Uuid
  direction WebhookDirection
  url       String?
  secret    String
  enabled   Boolean          @default(true)
  createdAt DateTime         @default(now()) @map("created_at")

  @@map("whatsapp_webhooks")
}

/// API key da plataforma para acesso externo (ex.: node Agent do n8n).
/// A key só é exibida na criação; persiste-se só o hash SHA-256.
model ApiKey {
  id          String    @id @default(uuid()) @db.Uuid
  label       String
  keyHash     String    @unique @map("key_hash")
  last4       String
  scopes      Json      @default("[]")
  revokedAt   DateTime? @map("revoked_at")
  createdById String?   @map("created_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("api_keys")
}

/// Idempotência do webhook receptor (evitar reprocessamento de mensagem WhatsApp).
/// Job de limpeza remove registros com processedAt > 7 dias.
model ProcessedWhatsappMessage {
  messageId   String   @id @map("message_id")
  processedAt DateTime @default(now()) @map("processed_at")
  userId      String?  @map("user_id")

  @@index([userId, processedAt])
  @@map("processed_whatsapp_messages")
}
