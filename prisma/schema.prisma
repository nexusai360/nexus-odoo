generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PlatformRole {
  super_admin
  admin
  manager
  viewer
}

enum Theme {
  dark
  light
  system
}

enum AuditAction {
  login_succeeded
  login_failed
  password_reset_requested
  password_reset_completed
  user_created
  user_updated
  user_deleted
  user_role_changed
  user_activated
  user_deactivated
  profile_updated
  profile_password_changed
  email_change_requested
  email_change_completed
  setting_updated
  session_revoked
  user_domains_changed
  // F5 — agente + WhatsApp + integrações
  user_whatsapp_added
  user_whatsapp_removed
  whatsapp_inbound_rejected
  agent_settings_updated
  llm_credential_created
  llm_credential_updated
  llm_credential_deleted
  api_key_created
  api_key_revoked
  whatsapp_channel_updated
}

// F5 — enums do agente e integrações
enum AgentChannel {
  whatsapp
  in_app
  playground
}

enum MessageRole {
  user
  assistant
  tool
}

enum KbKind {
  PDF
  TXT
  URL
  MARKDOWN
  CSV
  XML
}

/// Estado de checkpoint de um recurso do agente (áudio, imagem, KB, documento).
/// OFF = desativado; PLAYGROUND = ativo só no playground; PRODUCTION = ativo em produção.
enum FeatureCheckpoint {
  OFF
  PLAYGROUND
  PRODUCTION
}

enum WhatsappResponseMode {
  direct
  n8n_webhook
}

enum WebhookDirection {
  inbound
  outbound
}

enum ReportDomain {
  estoque
  financeiro
  fiscal
  comercial
  cadastros
  contabil
  rh
  crm
  producao
}

model User {
  id                  String               @id @default(uuid()) @db.Uuid
  email               String               @unique
  password            String
  name                String
  platformRole        PlatformRole         @default(viewer) @map("platform_role")
  isOwner             Boolean              @default(false) @map("is_owner")
  isActive            Boolean              @default(true) @map("is_active")
  mustChangePassword  Boolean              @default(true) @map("must_change_password")
  passwordChangedAt   DateTime?            @map("password_changed_at")
  avatarUrl           String?              @map("avatar_url")
  theme               Theme                @default(system)
  emailVerifiedAt     DateTime?            @map("email_verified_at")
  lastLoginAt         DateTime?            @map("last_login_at")
  lastLoginIp         String?              @map("last_login_ip")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  createdById         String?              @map("created_by_id") @db.Uuid
  createdBy           User?                @relation("UserCreator", fields: [createdById], references: [id])
  createdUsers        User[]               @relation("UserCreator")
  audits              AuditLog[]
  passwordResetTokens PasswordResetToken[]
  emailChangeTokens   EmailChangeToken[]
  domainAccess        UserDomainAccess[]   @relation("UserDomainAccess")
  reportPresets       ReportPreset[]
  // F5
  conversations       Conversation[]
  whatsappNumbers     UserWhatsappNumber[]
  playgroundSessions  PlaygroundSession[]

  @@index([platformRole, isActive])
  @@index([email])
  @@map("users")
}

/// Preset de configuração de visualização de um relatório (período + filtros).
/// Escopo: um preset pertence a um único usuário e a um único relatório do catálogo.
model ReportPreset {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reportId     String   @map("report_id")
  nome         String
  searchParams String   @map("search_params")
  favorito     Boolean  @default(false)
  criadoEm    DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  @@index([userId, reportId])
  @@map("report_presets")
}

model AppSetting {
  key         String   @id
  value       Json
  description String?
  category    String
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedById String?  @map("updated_by_id") @db.Uuid

  @@map("app_settings")
}

/// Servidor MCP externo registrado para o Agente Nex consumir como cliente.
/// "Plugar MCPs" — agrega capacidades de terceiros (Slack, GitHub, etc.) ao Nex.
/// O `authToken` é persistido cifrado (AES-256-GCM via src/lib/encryption.ts).
model ExternalMcpServer {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  description String?
  transport   String    @default("http")
  url         String
  authHeader  String?   @map("auth_header")
  authToken   String?   @map("auth_token")
  enabled     Boolean   @default(true)
  lastStatus  String    @default("unknown") @map("last_status")
  lastCheckAt DateTime? @map("last_check_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  callLogs ExternalMcpCallLog[]

  @@index([enabled])
  @@map("external_mcp_servers")
}

/// Registro das chamadas que o Agente Nex faz a tools de servidores MCP
/// externos (Plugar MCP). Distinto do McpAuditLog, que e do nosso MCP interno.
/// `serverName` e denormalizado para o log sobreviver a exclusao do servidor.
model ExternalMcpCallLog {
  id           String             @id @default(uuid()) @db.Uuid
  serverId     String?            @map("server_id") @db.Uuid
  server       ExternalMcpServer? @relation(fields: [serverId], references: [id], onDelete: SetNull)
  serverName   String             @map("server_name")
  toolName     String             @map("tool_name")
  outcome      String
  durationMs   Int?               @map("duration_ms")
  errorMessage String?            @map("error_message")
  argsPreview  Json?              @map("args_preview")
  userId       String             @map("user_id") @db.Uuid
  criadoEm     DateTime           @default(now()) @map("criado_em")

  @@index([criadoEm])
  @@index([serverId])
  @@map("external_mcp_call_log")
}

/// Registro de que um usuário já viu o tour de uma tela. Usado para abrir o
/// tour automaticamente só na primeira visita, sobrevivendo a logout e troca
/// de conta (a marca fica por usuário, não no navegador).
model UserTourSeen {
  id      String   @id @default(uuid()) @db.Uuid
  userId  String   @map("user_id") @db.Uuid
  tourKey String   @map("tour_key")
  seenAt  DateTime @default(now()) @map("seen_at")

  @@unique([userId, tourKey])
  @@map("user_tour_seen")
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String?     @map("user_id") @db.Uuid
  user       User?       @relation(fields: [userId], references: [id])
  action     AuditAction
  targetType String?     @map("target_type")
  targetId   String?     @map("target_id")
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  details    Json?
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

/// Concessão de domínio de relatório a um usuário. super_admin/admin não têm
/// linhas (veem tudo); manager/viewer têm uma linha por domínio concedido.
model UserDomainAccess {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  domain      ReportDomain
  grantedById String?      @map("granted_by_id") @db.Uuid
  createdAt   DateTime     @default(now()) @map("created_at")
  user        User         @relation("UserDomainAccess", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, domain])
  @@index([userId])
  @@map("user_domain_access")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, expiresAt])
  @@map("password_reset_tokens")
}

model EmailChangeToken {
