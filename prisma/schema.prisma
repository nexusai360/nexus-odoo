  atualizadoEm         DateTime  @default(now()) @map("atualizado_em")

  @@index([documentoId])
  @@map("fato_carta_correcao")
}

/// Entradas de referência (NCM, CFOP, município...) achatadas para lookup — F4 L1b.
model FatoReferencia {
  id        Int     @id @default(autoincrement())
  tabela    String
  codigo    String
  descricao String?

  @@index([tabela])
  @@index([tabela, codigo])
  @@map("fato_referencia")
}

/// Certificados digitais (e-CNPJ) das empresas — F4 L1c. Sem senha nem arquivo.
model FatoCertificado {
  odooId             Int       @id @map("odoo_id")
  tipo               String?
  numeroSerie        String?   @map("numero_serie")
  proprietario       String?
  cnpjCpf            String?   @map("cnpj_cpf")
  dataInicioValidade DateTime? @map("data_inicio_validade")
  dataFimValidade    DateTime? @map("data_fim_validade")
  dataVencimentoUtil DateTime? @map("data_vencimento_util")
  nomeArquivo        String?   @map("nome_arquivo")
  atualizadoEm       DateTime  @default(now()) @map("atualizado_em")

  @@index([dataFimValidade])
  @@map("fato_certificado")
}

// ─── F4 — Logs e feature requests do MCP ─────────────────────────────────────

/// Log de auditoria de chamadas ao MCP semântico.
model McpAuditLog {
  // LEGADOS — preservados (mcp/lib/audit.ts já usa)
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  tool       String
  params     Json
  outcome    String
  rowCount   Int?     @map("row_count")
  durationMs Int?     @map("duration_ms")
  criadoEm   DateTime @default(now()) @map("criado_em")

  // NOVOS — F4 Onda 2 (opcionais)
  apiKeyId       String? @map("api_key_id") @db.Uuid
  apiKey         ApiKey? @relation(fields: [apiKeyId], references: [id])
  authMode       String? @map("auth_mode")
  operation      String?
  module         String?
  action         String?
  capability     String?
  eventName      String? @map("event_name")
  requestId      String? @map("request_id")
  idempotencyKey String? @map("idempotency_key")
  payload        Json?
  result         Json?
  snapshotBefore Json?   @map("snapshot_before")
  snapshotAfter  Json?   @map("snapshot_after")
  status         String?
  httpStatus     Int?    @map("http_status")
  errorCode      String? @map("error_code")
  errorMessage   String? @map("error_message")
  ipAddress      String? @map("ip_address")
  userAgent      String? @map("user_agent")

  @@index([userId, criadoEm])
  @@index([apiKeyId, criadoEm(sort: Desc)])
  @@index([tool, criadoEm(sort: Desc)])
  @@index([status, criadoEm(sort: Desc)])
  @@index([idempotencyKey])
  @@index([module, action, criadoEm(sort: Desc)])
  @@index([eventName, criadoEm])
  @@map("mcp_audit_log")
}

/// Idempotency tracking para writes externas (F4 Onda 2).
/// PK composta (apiKeyId, key) isola Idempotency-Key por canal sem colisão.
model McpIdempotencyRecord {
  apiKeyId    String   @map("api_key_id") @db.Uuid
  key         String
  toolId      String   @map("tool_id")
  payloadHash String   @map("payload_hash")
  result      Json
  status      String
  httpStatus  Int      @map("http_status")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@id([apiKeyId, key])
  @@index([expiresAt])
  @@map("mcp_idempotency_records")
}

/// Registro de perguntas fora do catálogo (Caminho 3a — gap logging).
model FeatureRequest {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  perguntaResumo String   @map("pergunta_resumo")
  dominio        String?
  criadoEm       DateTime @default(now()) @map("criado_em")

  @@map("feature_requests")
}

// ─── F5 — Agente de IA + WhatsApp + Integrações ──────────────────────────────

/// Número de WhatsApp vinculado a um usuário da plataforma (N por usuário).
model UserWhatsappNumber {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  phoneE164  String    @unique @map("phone_e164")
  label      String?
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("user_whatsapp_numbers")
}

/// Conversa de agente (WhatsApp, in-app ou playground).
/// Agrupamento: WhatsApp → automático (< 24h); in-app/playground → explícito.
model Conversation {
  id                 String                          @id @default(uuid()) @db.Uuid
  userId             String                          @map("user_id") @db.Uuid
  user               User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel            AgentChannel
  title              String?
  /// Historico opaco de raciocinio por iteracao (Anthropic blocks, Gemini parts,
  /// OpenRouter reasoning_details, OpenAI reasoning items). Array crescente,
  /// capado em 20 iteracoes ou 50KB serialized. Cada item: { provider, data }.
  reasoningHistory   Json                            @default("[]") @map("reasoning_history")
  /// Onda M (Arquitetura 3.0): working memory estruturada , metrica/periodo/
  /// entidades/ultimo resultado em foco. Derivada por regra no fim do turno
  /// (src/lib/agent/memoria/foco-atual.ts) e injetada como L4 no prompt.
  focoAtual          Json?                           @map("foco_atual")
  entidades          ConversationEntity[]
  /// Onda M (M.5): resumo progressivo da conversa (L2 da memoria). Texto
  /// factual com numeros+proveniencia, re-gerado async (job
  /// `agent-resumo-conversa`) sempre a partir das mensagens originais.
  resumoProgressivo  String?                         @map("resumo_progressivo") @db.Text
  /// Cursor: id da ultima mensagem incluida no resumo.
  resumoAteMensagemId String?                        @map("resumo_ate_mensagem_id")
  resumoAtualizadoEm DateTime?                       @map("resumo_atualizado_em")
  /// Dominios dos dados contidos no resumo (RBAC lazy da injecao).
  resumoDominios     String[]                        @default([]) @map("resumo_dominios")
  /// Tags de topico/dominio derivadas das mensagens do usuario na conversa.
  /// Populado pelo job assincrono `agent-topic-tagging` (Onda 1 Inteligencia).
  /// Cap 5 tags. Ex.: ["estoque", "keyword:saldo", "produto:mola_espiral"].
  topicTags          String[]                        @default([]) @map("topic_tags")
  /// Versao do algoritmo de tagging. Incrementar forca re-tag em backfill.
  topicTagsVersion   Int                             @default(0) @map("topic_tags_version")
  /// Quando foi tagueado pela ultima vez. Usado para decidir re-tag a cada
  /// 10 mensagens novas.
  topicTagsAt        DateTime?                       @map("topic_tags_at")
  createdAt          DateTime                        @default(now()) @map("created_at")
  updatedAt          DateTime                        @updatedAt @map("updated_at")
  /// Quando a conversa foi encerrada/arquivada pelo usuario ("Limpar sessao").
  /// null = ativa. Arquivadas nao reabrem, mas permanecem para auditoria/export.
  endedAt            DateTime?                       @map("ended_at")
  messages           Message[]
  qualityEvaluations ConversationQualityEvaluation[]
  /// R1 router de catalogo: decisoes do router por turno desta conversa.
  routerDecisions    AgentRouterDecision[]
  messageFeedback    MessageFeedback[]

  @@index([userId, updatedAt])
  @@index([userId, channel, endedAt, updatedAt])
  @@map("conversations")
}

/// Mensagem de conversa (user, assistant ou tool).
/// Onda M (Arquitetura 3.0) T4.1: entidades citadas na conversa (anafora por
/// recencia). Upsert no fim do turno (src/lib/agent/memoria/entidades.ts).
model ConversationEntity {
  id             String       @id @default(cuid())
  conversationId String       @map("conversation_id") @db.Uuid
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tipo           String
  chaveCanonica  String       @map("chave_canonica")
  rotulo         String
  ultimoTurno    Int          @map("ultimo_turno")
  mencoes        Int          @default(1)

  @@unique([conversationId, tipo, chaveCanonica])
  @@index([conversationId, ultimoTurno])
  @@map("conversation_entities")
}

model Message {
  id              String                @id @default(uuid()) @db.Uuid
  conversationId  String                @map("conversation_id") @db.Uuid
  conversation    Conversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            MessageRole
  content         String
  toolCalls       Json?                 @map("tool_calls")
  /// Resultados das tool calls deste turno, em formato canonico cross-provider
  /// (Array<{ name, args, result }>). NULL em mensagens pre-Onda 1 Inteligencia.
  /// Spec: docs/superpowers/specs/2026-05-25-agente-nex-inteligencia-design.md §3.2.
  toolResults     Json?                 @map("tool_results")
  /// Onda M (Arquitetura 3.0): digest 1-linha-por-call dos toolResults (tool,
  /// dominio, args-chave, numeros). E o que sobrevive no replay do historico
  /// quando o payload bruto sai do contexto. Derivado em updateMessageToolResults.
  toolDigest      String?               @map("tool_digest") @db.Text
  kind            String                @default("text") @map("kind")
  createdAt       DateTime              @default(now()) @map("created_at")
  /// R1 router de catalogo: decisao do router associada a este turno.
  routerDecisions AgentRouterDecision[]
  messageFeedback MessageFeedback[]

  @@index([conversationId, createdAt])
  @@map("messages")
}

/// B1. Voto vigente do usuario sobre uma resposta do agente (1 por mensagem+usuario,
/// ultimo vale). Historico completo em MessageFeedbackEvent.
model MessageFeedback {
  id                 String             @id @default(uuid()) @db.Uuid
  conversationId     String             @map("conversation_id") @db.Uuid
  assistantMessageId String             @map("assistant_message_id") @db.Uuid
  userId             String             @map("user_id") @db.Uuid
  rating             UserFeedbackRating
  comment            String?            @db.VarChar(150)
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  conversation Conversation           @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message                @relation(fields: [assistantMessageId], references: [id], onDelete: Cascade)
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  events       MessageFeedbackEvent[]

  @@unique([assistantMessageId, userId])
  @@index([conversationId])
  @@index([userId])
  @@map("message_feedback")
}

/// B1. Historico append-only de cada voto/troca/comentario (fonte do aprendizado B3).
model MessageFeedbackEvent {
  id         String                @id @default(uuid()) @db.Uuid
  feedbackId String                @map("feedback_id") @db.Uuid
  rating     UserFeedbackRating
  comment    String?               @db.VarChar(150)
  action     MessageFeedbackAction
  createdAt  DateTime              @default(now()) @map("created_at")

  feedback MessageFeedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@index([feedbackId, createdAt])
  @@map("message_feedback_event")
}

/// Credencial de API de LLM — chave cifrada com AES-256.
model LlmCredential {
  id              String      @id @default(uuid()) @db.Uuid
  provider        String
  label           String
  encryptedApiKey String      @map("encrypted_api_key")
  last4           String
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  createdById     String?     @map("created_by_id") @db.Uuid
  configs         LlmConfig[]

  /// Saldo/crédito da conta do provedor para esta chave.
  /// balanceStatus: "ok" (valor real), "unavailable" (provedor sem API de saldo),
  /// "error" (consulta falhou). balanceUsd nulo quando status != "ok".
  balanceUsd       Decimal?  @map("balance_usd") @db.Decimal(14, 4)
  balanceCurrency  String?   @map("balance_currency")
  balanceStatus    String?   @map("balance_status")
  balanceCheckedAt DateTime? @map("balance_checked_at")

  @@unique([provider, label])
  @@index([provider, updatedAt(sort: Desc)])
  @@map("llm_credentials")
}

/// Configuração LLM ativa (provider + model + credencial).
/// Ativar é transacional: desativa todas e ativa a escolhida.
model LlmConfig {
  id           String         @id @default(uuid()) @db.Uuid
  provider     String
  model        String
  credentialId String?        @map("credential_id") @db.Uuid
  credential   LlmCredential? @relation(fields: [credentialId], references: [id])
  isActive     Boolean        @default(false) @map("is_active")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@map("llm_configs")
}

/// Registro de uso de LLM por iteração do loop de tool calling.
/// costUsd = null quando costKnown = false (modelo sem preço no catálogo).
/// costBrl calculado com cotação versionada; rateStale=true se cotação falhou.
model LlmUsage {
  id                String   @id @default(uuid()) @db.Uuid
  conversationId    String?  @map("conversation_id") @db.Uuid
  provider          String
  model             String
  tokensInput       Int      @map("tokens_input")
  tokensOutput      Int      @map("tokens_output")
  /// Tokens de input servidos do cache de prompt do provider (alavanca 1).
  /// Custam fracao do input normal; subset conceitual de tokens_input.
  tokensCachedInput Int      @default(0) @map("tokens_cached_input")
  costUsd           Decimal? @map("cost_usd") @db.Decimal(18, 10)
  costKnown         Boolean  @default(true) @map("cost_known")
  costBrl           Decimal? @map("cost_brl") @db.Decimal(20, 10)
  usdToBrlRate      Decimal? @map("usd_to_brl_rate") @db.Decimal(10, 4)
  rateSpread        Decimal? @map("rate_spread") @db.Decimal(6, 4)
  rateStale         Boolean  @default(false) @map("rate_stale")
  promptChars       Int?     @map("prompt_chars")
  responseChars     Int?     @map("response_chars")
  durationMs        Int?     @map("duration_ms")
  errorMessage      String?  @map("error_message")
  isPlayground      Boolean  @default(false) @map("is_playground")
  /// Tokens de raciocinio internos (subset conceitual de tokens_output).
  /// OpenAI/Gemini/OpenRouter expoem; Anthropic nao (fica NULL).
  reasoningTokens   Int?     @map("reasoning_tokens")
  /// Contagem de tool calls disparadas nesta iteracao. NULL em linhas
  /// antigas pre-instrumentacao; 0 quando o modelo respondeu direto
  /// sem chamar tool. Usado no drill-down de /agente/consumo.
  toolCallsCount    Int?     @map("tool_calls_count")
  /// Nomes das tools chamadas nesta iteracao, na ordem em que foram
  /// requisitadas pelo modelo. Array vazio quando nenhuma tool foi
  /// chamada; NULL em linhas antigas pre-instrumentacao.
  toolNames         String[] @map("tool_names")
  userId            String?  @map("user_id") @db.Uuid
  // Credencial (chave de API) usada — permite somar o consumo por chave (A4).
  credentialId      String?  @map("credential_id") @db.Uuid
  // Tipo da requisição para a tag de Consumo (G11): texto/imagem/audio/arquivo/embedding.
  requestKind       String   @default("texto") @map("request_kind")
  /// Origem da chamada para a tag "Origem" do menu de consumo. NULL em linhas
  /// antigas (derivam de isPlayground: Agente Nex / Playground). Valores novos:
  /// "router" (router de catalogo em producao) e "router_calibracao" (rodadas
  /// de calibragem offline). Permite distinguir gasto do router no historico.
  origin            String?  @map("origin")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([provider, model, createdAt])
  @@index([credentialId])
  @@map("llm_usage")
}

/// Configuração do agente — singleton (id="global").
model AgentSettings {
  id                 String  @id @default("global")
  identityBase       String? @map("identity_base")
  personality        String  @default("")
  tone               String  @default("")
  guardrails         Json    @default("[]")
  terminology        Json    @default("{}")
  advancedOverride   String? @map("advanced_override")
  suggestionsEnabled Boolean @default(true) @map("suggestions_enabled")

  /// **CONTROLE DE FONTE DA VERDADE PRO PROMPT** (resolve drift dev/banco):
  ///
  /// - TRUE  (default): agente usa IDENTITY_BASE, DEFAULT_PERSONALITY,
  ///   DEFAULT_TONE e DEFAULT_GUARDRAILS do CÓDIGO. Os campos `identityBase`,
  ///   `personality`, `tone` e `guardrails` no banco são IGNORADOS.
  ///   Dev pode editar o código e a mudança REFLETE imediatamente.
  /// - FALSE: admin customizou via UI `/agente/prompt`. Usa o banco.
  ///
  /// Auto-flip pra FALSE quando admin SALVA via UI.
  /// Pra voltar a TRUE: botão "Voltar ao padrão do sistema" na UI.
  usesCodeDefaults Boolean @default(true) @map("uses_code_defaults")

  /// Exibição da bolha flutuante do Agente Nex nas páginas autenticadas.
  bubbleEnabled Boolean @default(true) @map("bubble_enabled")

  /// Habilita o Agente Nex no canal WhatsApp (F5). Independente de bubble.
  whatsappEnabled Boolean @default(true) @map("whatsapp_enabled")

  /// F5: nível mínimo de acesso da bubble in-app. Default viewer = todos (preserva bubbleEnabled=true).
  bubbleAccessLevel   ChannelAccessLevel @default(viewer) @map("bubble_access_level")
  /// F5: nível mínimo de acesso do canal WhatsApp. Default viewer = todos (preserva whatsappEnabled=true).
  whatsappAccessLevel ChannelAccessLevel @default(viewer) @map("whatsapp_access_level")

  /// Checkpoints de 3 estados (OFF/PLAYGROUND/PRODUCTION).
  audioCheckpoint       FeatureCheckpoint @default(OFF) @map("audio_checkpoint")
  imageCheckpoint       FeatureCheckpoint @default(OFF) @map("image_checkpoint")
  feedbackCheckpoint    FeatureCheckpoint @default(OFF) @map("feedback_checkpoint")
  kbCheckpoint          FeatureCheckpoint @default(PRODUCTION) @map("kb_checkpoint")
  /// Checkpoint das sugestões clicáveis (substitui suggestionsEnabled — B3).
  suggestionsCheckpoint FeatureCheckpoint @default(PRODUCTION) @map("suggestions_checkpoint")

  /// Checkpoint de 3 estados do modo raciocínio (OFF/PLAYGROUND/PRODUCTION).
  /// Controla em qual ambiente o reasoning_effort é aplicado.
  reasoningCheckpoint FeatureCheckpoint @default(OFF) @map("reasoning_checkpoint")
  /// Profundidade de raciocínio dos modelos reasoning (ex.: GPT-5.x).
  /// null = usa o default do provider. Valores: minimal | low | medium | high.
  reasoningEffort     String?           @map("reasoning_effort")

  /// Máximo de sugestões clicáveis que o agente pode mostrar por resposta.
  /// Aplicado deterministicamente em `extractSuggestions` e instruído no prompt.
  maxSuggestions Int @default(3) @map("max_suggestions")

  /// AutoValidator (Onda 1.E do projeto Nex >=90%): valida a resposta final
  /// do LLM antes de devolver ao usuário. 3 modos:
  ///   off    = não roda
  ///   shadow = roda V1-V4, loga retryReason, NÃO retenta
  ///   active = roda V1-V4, dispara 1 retry com hint corretivo se falhar
  /// Default: shadow (seguro). Promover para active após validar FP rate em log.
  /// Onda O (Arquitetura 3.0): tier T3 , perguntas explicativas/contestacao
  /// rodam no modelo forte. OFF = sempre mini (rollback). Cascata: reprova do
  /// validador tambem re-tenta no forte quando a flag esta ativa.
  tierT3Checkpoint FeatureCheckpoint @default(OFF) @map("tier_t3_checkpoint")
  /// Modelo forte do T3 (null = default do codigo: gpt-5.4).
  tierT3Model      String?           @map("tier_t3_model")

  autoValidatorMode  String  @default("shadow") @map("auto_validator_mode")
  validatorV1Enabled Boolean @default(true) @map("validator_v1_enabled")
  validatorV2Enabled Boolean @default(true) @map("validator_v2_enabled")
  validatorV3Enabled Boolean @default(true) @map("validator_v3_enabled")
  validatorV4Enabled Boolean @default(true) @map("validator_v4_enabled")

  /// Modelo usado em chamadas internas de inteligencia (topic-extractor,
  /// contextual-suggester). Formato: "provider/model" ex. "anthropic/claude-haiku-4-5".
  /// NULL = default Haiku 4.5 via OpenRouter.
  intelligenceModel      String?           @map("intelligence_model")
  /// Modelo do juiz de qualidade (Frente A da inteligencia). NULL = Gemini 2.5
  /// Pro thinking via OpenRouter (fallback: Opus 4.7).
  qualityJudgeModel      String?           @map("quality_judge_model")
  /// Checkpoint das frentes B/C/D da inteligencia (welcome personalizado,
  /// sugestoes contextuais, bullets-pergunta para chips). Default OFF para
  /// rollout controlado. Frente A (analise retrospectiva) e admin-only e
  /// nao respeita este checkpoint.
  intelligenceCheckpoint FeatureCheckpoint @default(OFF) @map("intelligence_checkpoint")

  /// Modelo dedicado de transcrição de áudio (independente do modelo de produção).
  audioProvider     String? @map("audio_provider")
  audioModel        String? @map("audio_model")
  /// Credencial (chave de API) usada pelo modelo dedicado de áudio.
  audioCredentialId String? @map("audio_credential_id") @db.Uuid

  /// Modelo dedicado de entendimento de imagem (independente do modelo de produção).
  imageProvider     String? @map("image_provider")
  imageModel        String? @map("image_model")
  /// Credencial (chave de API) usada pelo modelo dedicado de imagem.
  imageCredentialId String? @map("image_credential_id") @db.Uuid

  /// Modelo do agente construtor de relatorios (F6). Independente do modelo de
  /// producao do Nex. Default no codigo (openai/gpt-5-mini) quando vazio.
  builderModelProvider String? @map("builder_model_provider")
  builderModelId       String? @map("builder_model_id")

  /// R1 router de catalogo (sub-projeto do roadmap de cobertura completa).
  /// Ver docs/superpowers/specs/2026-05-28-router-catalogo-design.md.
  /// FALSE (default): modo shadow — calcula decisao mas nao filtra catalogo.
  /// TRUE: filtra catalogo entregue ao LLM por similaridade semantica.
  routerEnabled          Boolean @default(false) @map("router_enabled")
  /// Threshold minimo de cosine similarity para incluir dominio (regra 5).
  routerThreshold        Float   @default(0.30) @map("router_threshold")
  /// Quantos dominios sao escolhidos no topo (regra 5).
  routerTopK             Int     @default(3) @map("router_top_k")
  /// Em modo ativo, se V1-V5 detectar Caminho 3a e topScore < este threshold,
  /// dispara retry expandindo catalogo para o inteiro (uso do motor existente).
  routerRetryExpandBelow Float   @default(0.70) @map("router_retry_expand_below")
  /// Habilita o retry expandido descrito acima. Default false para rollout
  /// seguro: liga so depois de validar shadow.
  routerRetryEnabled     Boolean @default(false) @map("router_retry_enabled")
  /// F3 (cerebro): retrieval de tool individual por embedding (separado do
  /// routerEnabled de dominio, que e Boolean). "shadow" (default): calcula o
  /// top-K e loga em AgentRouterDecision, mas NAO enxuga o catalogo. "active":
  /// entrega so o catalogo enxuto (top-K + nucleo minimo) ao LLM. Vira active
  /// so apos shadow-compare provar recall@K >= 98% (spec F3 secao 4.5).
  routerToolRetrieval    String  @default("shadow") @map("router_tool_retrieval")

  /// R2-ctx: roteamento contextual (Camada 2). Quando o embedding cai em
  /// fallback, uma LLM barata reformula a pergunta com os ultimos N pares e o
  /// router re-embedda a versao enriquecida. Nasce OFF: liga apos validar.
  /// Ver docs/superpowers/specs/2026-05-29-roteamento-contextual-e-janela-de-contexto-design.md.
  routerReformCheckpoint   FeatureCheckpoint @default(OFF) @map("router_reform_checkpoint")
  routerReformProvider     String?           @map("router_reform_provider")
  routerReformModel        String?           @map("router_reform_model")
  routerReformCredentialId String?           @map("router_reform_credential_id") @db.Uuid
  /// Quantos pares (user -> resposta final) entram no contexto da reformulacao.
  routerReformNPairs       Int               @default(5) @map("router_reform_n_pairs")
  /// Escolha de modelo de embedding do router. A CREDENCIAL continua na fonte
  /// unica compartilhada com o RAG (AppSetting embedding_credential_id); aqui
  /// guardamos so o nome do modelo (ex.: text-embedding-3-large).
  routerEmbeddingModel     String?           @map("router_embedding_model")

  /// R2-ctx: janela de contexto da resposta do agente (loadHistory). Default
  /// preserva o comportamento atual (20 mensagens, todos os papeis).
  /// OFF = sem historico; PLAYGROUND = so playground; PRODUCTION = bubble +
  /// WhatsApp + playground. Tamanho com trava 10..50 aplicada em runtime.
  contextWindowCheckpoint    FeatureCheckpoint @default(PRODUCTION) @map("context_window_checkpoint")
  contextWindowSize          Int               @default(20) @map("context_window_size")
  /// true = inclui mensagens de sistema/tool no historico; false = so user + IA.
  contextWindowIncludeSystem Boolean           @default(true) @map("context_window_include_system")

  /// Periodicidade (em minutos) do cron BullMQ que processa avaliacoes
  /// PENDENTE via heuristica (sem custo de LLM). Range 1-1440 (24h).
  /// Default 240 (4h). Configurado no painel /agente/monitoramento aba
  /// Backtest. Mudancas sao aplicadas em ate 60s pelo JOB_CONFIG_CHECK
  /// do worker (mesmo mecanismo do sync incremental).
  qualityHeuristicIntervalMinutes Int @default(240) @map("quality_heuristic_interval_minutes")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("agent_settings")
}

/// R1 router de catalogo (sub-projeto do roadmap de cobertura completa do Odoo).
/// Ver docs/superpowers/specs/2026-05-28-router-catalogo-design.md §6.
/// Cada turno do agente Nex gera uma linha aqui: o que o router decidiu, o que
/// foi de fato chamado (tools), e em qual modo (shadow vs active). Permite
/// auditar acerto top-1 sem afetar o comportamento atual do Nex.
model AgentRouterDecision {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  /// Contexto do turno. Opcionais porque a row e' criada antes da persistencia
  /// da Message no banco.
  conversationId String?       @map("conversation_id") @db.Uuid
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  messageId      String?       @map("message_id") @db.Uuid
  message        Message?      @relation(fields: [messageId], references: [id], onDelete: SetNull)

  /// Entrada.
  userQuestion       String @map("user_question") @db.Text
  questionTokenCount Int?   @map("question_token_count")

  /// Saida do router. `scores` e' Json {dominio: score}. `topScore` denormalizado
  /// para facilitar queries de histograma (width_bucket). Em fallbacks tipo
  /// msg_trivial ou embed_failed, `scores` = {} e `topScore` = null.
  pickedDomains     String[] @default([]) @map("picked_domains")
  scores            Json     @default("{}")
  topScore          Float?   @map("top_score")
  fallbackTriggered Boolean  @default(false) @map("fallback_triggered")
  /// "msg_trivial" | "embed_failed" | "score_baixo" | null. Pode ganhar sufixo
  /// "+retry_v5_expanded" quando o retry V1-V5 expandiu o catalogo.
  fallbackReason    String?  @map("fallback_reason")
  /// Formato: "r1.<major>.<minor>.<patch>-<vocab_hash8>". Permite cruzar com
  /// VOCABULARY_VERSION.
  routerVersion     String   @map("router_version")

  /// O que aconteceu no turno. `mode`: "shadow" | "active" | "calibracao_R-X"
  /// | "test" | "e2e".
  mode               String
  catalogSizeOffered Int      @default(0) @map("catalog_size_offered")
  catalogSizeFull    Int      @default(0) @map("catalog_size_full")
  toolsActuallyUsed  String[] @default([]) @map("tools_actually_used")
  toolsDomains       String[] @default([]) @map("tools_domains")
  llmModelUsed       String?  @map("llm_model_used")
  /// Tempo da chamada pickDomains, nao do turno todo. Alarmavel quando p95 >
  /// 200ms.
  pickDurationMs     Int?     @map("pick_duration_ms")

  /// RBAC v2: desfecho do turno do ponto de vista do router/permissão.
  /// Valores esperados (TEXT, não enum por extensibilidade):
  ///   - "ok"                  → turno completou normalmente (LLM respondeu)
  ///   - "permission_denied"   → fast-path de recusa disparou (sem LLM)
  ///   - "failed"              → exceção não tratada (futuro)
  /// Default null preserva linhas históricas pré-RBAC v2.
  outcome String? @db.Text

  /// R2-ctx: roteamento contextual (3 camadas). Quando a Camada 1 (embedding da
  /// pergunta crua) cai em fallback e a Construcao da pergunta esta ativa, uma
  /// LLM reformula e o router re-embedda. Estes campos preservam a origem:
  ///   originalFallback     = a Camada 1 caiu em fallback (gatilho).
  ///   usedReformulation    = a Camada 2 (LLM) rodou e produziu pergunta nova.
  ///   reformulatedQuestion = a pergunta enriquecida usada no re-embedding.
  /// A decisao gravada (pickedDomains/scores) e' a FINAL (Camada 3 quando houve
  /// reformulacao). Defaults preservam linhas historicas.
  originalFallback     Boolean @default(false) @map("original_fallback")
  usedReformulation    Boolean @default(false) @map("used_reformulation")
  reformulatedQuestion String? @map("reformulated_question") @db.Text

  /// F3 (cerebro): shadow-compare do retrieval de TOOL (separado do router de
  /// dominio). `retrievalOfferedTools` = top-K + nucleo que o retrieval ofereceria
  /// (ordenado por score desc). `retrievalScores` = {toolName: cosseno}.
  /// `chosenToolRank` = posicao (0-based) da tool que o LLM usou dentro do ranking
  /// oferecido, ou null se fora do top-K. Gate de go-live: % de turnos com
  /// chosenToolRank != null >= 98% (spec F3 secao 4.5). Defaults preservam historico.
  retrievalOfferedTools String[] @default([]) @map("retrieval_offered_tools")
  retrievalScores       Json?    @map("retrieval_scores")
  chosenToolRank        Int?     @map("chosen_tool_rank")

  @@index([createdAt, mode])
  @@index([conversationId])
  @@index([routerVersion])
  @@map("agent_router_decision")
}

/// Overrides do catálogo de modelos LLM. Modelos novos descobertos pelo botão
/// "atualizar" (ou pelo script CLI) ficam aqui; o catálogo efetivo em runtime
/// é o merge de catalog.ts (base) + esta tabela. Tabela vazia = usa só a base.
model LlmModelEntry {
  id               String    @id
  provider         String
  label            String
  tier             String
  pricingInput     Float?    @map("pricing_input")
  pricingOutput    Float?    @map("pricing_output")
  pricingPerMinute Float?    @map("pricing_per_minute")
  modelUse         String?   @map("model_use")
  audio            Boolean   @default(false)
  vision           Boolean   @default(false)
  reasoningLevels  Json?     @map("reasoning_levels")
  released         String?
  notes            String?
  source           String    @default("sync")
  /// Quando o modelo some do catalogo upstream, marca o instante;
  /// permite manter selecao do usuario e exibir banner de deprecated.
  deprecatedAt     DateTime? @map("deprecated_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([provider])
  @@map("llm_model_entry")
}

/// Documento da base de conhecimento do agente.
/// A coluna embedding vector(1536) é adicionada via SQL raw na migration (pgvector, onda 7).
model KbDocument {
  id            String                       @id @default(uuid()) @db.Uuid
  name          String
  kind          KbKind                       @default(TXT)
  sourceUrl     String?                      @map("source_url")
  extractedText String                       @map("extracted_text")
  charCount     Int                          @map("char_count")
  /// Checkpoint do documento: OFF, PLAYGROUND ou PRODUCTION.
  checkpoint    FeatureCheckpoint            @default(PRODUCTION)
  createdAt     DateTime                     @default(now()) @map("created_at")
  /// Embedding pgvector(1536) para RAG. Tipo sem suporte nativo no Prisma —
  /// declarado com `Unsupported` para que `prisma migrate dev` NÃO o derrube.
  /// O índice HNSW vive em migration raw (Prisma não modela índice de vetor).
  embedding     Unsupported("vector(1536)")?

  @@map("kb_documents")
}

/// Sessão persistente do playground do Agente Nex.
/// Cada sessão tem provedor/modelo próprios, snapshot de prompt editável
/// e histórico de mensagens com custo acumulado. Independente da produção.
model PlaygroundSession {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String?
  provider       String
  model          String
  /// Chave de API usada nesta sessão (D2) — desacopla da config global.
  credentialId   String?   @map("credential_id") @db.Uuid
  /// Conversa (canal playground) usada pelo runAgent para histórico/contexto.
  /// Criada sob demanda na primeira mensagem da sessão.
  conversationId String?   @map("conversation_id") @db.Uuid
  /// Snapshot do prompt da sessão: { identityBase, personality, tone, guardrails }.
  /// Inicia como cópia da produção; editável sem afetar produção.
  promptSnapshot Json      @map("prompt_snapshot")
  costUsd        Decimal   @default(0) @map("cost_usd") @db.Decimal(14, 6)
  costBrl        Decimal   @default(0) @map("cost_brl") @db.Decimal(14, 6)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  /// Preenchido quando a sessão é arquivada ("Nova sessão").
  archivedAt     DateTime? @map("archived_at")

  messages PlaygroundMessage[]

  @@index([userId, updatedAt(sort: Desc)])
  @@map("playground_sessions")
}

/// Mensagem de uma sessão de playground.
model PlaygroundMessage {
  id          String            @id @default(uuid()) @db.Uuid
  sessionId   String            @map("session_id") @db.Uuid
  session     PlaygroundSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role        MessageRole
  content     String
  toolCalls   Json?             @map("tool_calls")
  costUsd     Decimal?          @map("cost_usd") @db.Decimal(12, 6)
  /// Provedor que gerou esta mensagem (D5) — registra por turn.
  provider    String?           @map("provider")
  /// Modelo que gerou esta mensagem (D5).
  model       String?           @map("model")
  /// Tipo de requisição (D5/G11): texto, audio, imagem, arquivo.
  requestKind String?           @map("request_kind")
  createdAt   DateTime          @default(now()) @map("created_at")

  @@index([sessionId, createdAt])
  @@map("playground_messages")
}

/// Canal WhatsApp — singleton (id="global") com credenciais Meta + modo de resposta.
model WhatsappChannel {
  id                String               @id @default("global")
  encryptedApiToken String?              @map("encrypted_api_token")
  businessAccountId String?              @map("business_account_id")
  phoneNumberId     String?              @map("phone_number_id")
  responseMode      WhatsappResponseMode @default(direct)
  enabled           Boolean              @default(false)
  updatedAt         DateTime             @updatedAt @map("updated_at")

  @@map("whatsapp_channel")
}

/// Webhook configurado (inbound = receptor; outbound = n8n callback).
/// Campos `name`, `path`, `targetUrl` e `methods` adicionados na rodada 6
/// (F4) — aditivos, sem quebrar o receptor de WhatsApp da F5 que usa
/// `direction`/`url`/`secret`/`enabled`.
model WhatsappWebhook {
  id        String           @id @default(uuid()) @db.Uuid
  direction WebhookDirection
  /// Rótulo amigável do webhook (R6).
  name      String?
  /// Descrição livre do que este webhook faz (F5.1).
  description String?
  url       String?
  /// Caminho (slug) para webhooks de entrada — o que vem após a URL base (R6).
  path      String?
  /// URL de destino completa para webhooks de saída (R6).
  targetUrl String?          @map("target_url")
  /// Métodos HTTP aceitos (GET/POST/PUT/PATCH/DELETE) (R6).
  methods   String[]         @default([])
  /// Eventos que este webhook de saída emite (F5). Vazio = nenhum.
  events    WebhookEvent[]   @default([])
  /// F5.1: webhook de entrada que recebe dados de mensagens do WhatsApp (via
  /// n8n) e alimenta o Agente Nex. Só vale para direction=inbound.
  isWhatsappReceiver Boolean @default(false) @map("is_whatsapp_receiver")
  /// F5.1: número da empresa (WhatsApp Business) que este receptor atende.
  /// Único entre os receptores de WhatsApp; vira a tag no card.
  businessId String?         @map("business_id")
  secret    String
  enabled   Boolean          @default(true)
  createdAt DateTime         @default(now()) @map("created_at")

  instances WhatsappInstance[]

  @@unique([businessId])
  @@map("whatsapp_webhooks")
}

/// Instância do canal WhatsApp — substitui o singleton WhatsappChannel (R6).
/// Cada instância tem credenciais Meta próprias, modo de resposta e um
/// webhook associado.
model WhatsappInstance {
  id                String               @id @default(uuid()) @db.Uuid
  name              String
  phoneNumber       String               @map("phone_number")
  /// Token da Graph API (cifrado AES-256).
  graphApiToken     String?              @map("graph_api_token")
  businessAccountId String?              @map("business_account_id")
  phoneNumberId     String?              @map("phone_number_id")
  responseMode      WhatsappResponseMode @default(direct) @map("response_mode")
  webhookId         String?              @map("webhook_id") @db.Uuid
  webhook           WhatsappWebhook?     @relation(fields: [webhookId], references: [id])
  enabled           Boolean              @default(true)
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  @@index([webhookId])
  @@map("whatsapp_instances")
}

/// API key da plataforma para acesso externo (ex.: node Agent do n8n).
/// A key só é exibida na criação; persiste-se só o hash SHA-256.
model ApiKey {
  // EXISTENTES — preservados
  id          String    @id @default(uuid()) @db.Uuid
  label       String
  keyHash     String    @unique @map("key_hash")
  last4       String
  scopes      Json      @default("[]") // deprecated — migrado para capabilities em B4.5
  revokedAt   DateTime? @map("revoked_at")
  createdById String?   @map("created_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")

  // NOVOS — F4 Onda 2
  description         String?
  capabilities        Json      @default("{\"version\":1,\"read\":[],\"write\":{}}")
  capabilitiesVersion Int       @default(1) @map("capabilities_version")
  rateLimit           Int       @default(60) @map("rate_limit")
  active              Boolean   @default(true)
  expiresAt           DateTime? @map("expires_at")
  lastUsedAt          DateTime? @map("last_used_at")
  rotatedAt           DateTime? @map("rotated_at")
  revokedReason       String?   @map("revoked_reason")
  isSystemKey         Boolean   @default(false) @map("is_system_key")
  tenantId            String?   @map("tenant_id") @db.Uuid
  allowedOrigins      Json      @default("[]") @map("allowed_origins")

  auditLogs McpAuditLog[]

  @@index([active, revokedAt, expiresAt])
  @@index([tenantId, active])
  @@index([last4])
  @@map("api_keys")
}

/// Idempotência do webhook receptor (evitar reprocessamento de mensagem WhatsApp).
/// Job de limpeza remove registros com processedAt > 7 dias.
model ProcessedWhatsappMessage {
  messageId   String   @id @map("message_id")
  processedAt DateTime @default(now()) @map("processed_at")
  userId      String?  @map("user_id")

  @@index([userId, processedAt])
  @@map("processed_whatsapp_messages")
}

// ─── F4.5 — Agente Nex Inteligencia ─────────────────────────────────────────
//
// Spec canonica: docs/superpowers/specs/2026-05-25-agente-nex-inteligencia-design.md (v3)
// Plan canonico: docs/superpowers/plans/2026-05-25-agente-nex-inteligencia-plan.md (v3)
//
// Quatro frentes:
//   A. Analise retrospectiva (ConversationQualityEvaluation, PromptRecommendation)
//   B. Welcome personalizado (UserAgentProfile)
//   C. Continuidade contextual (SuggestionInteraction + dedup runtime)
//   D. Bullets-pergunta -> chips (sem persist novo; consolida extractor existente)

/// Perfil de interacao do usuario: personaliza prompt individual + sugestoes (welcome e por
/// resposta). Camada DETERMINISTICA (Onda 1) atualizada pelo job BullMQ `profile-aggregate` no
/// worker (SQL puro, sem claude/OpenAI, roda em prod). Camada DESTILADA por LLM (Onda 2,
/// host-side) preenche interactionPrompt/presentationPrefs sutis. Guarda APENAS derivados ,
/// nenhuma frase original do usuario (recurringQuestions.label = tema de vocabulario fechado).
model UserAgentProfile {
  userId            String    @id @map("user_id") @db.Uuid
  /// [{topic, score, lastSeenAt}], ordenado por score (recencia x frequencia).
  topTopics         Json      @default("[]") @map("top_topics")
  /// [{keyword, score}].
  topKeywords       Json      @default("[]") @map("top_keywords")
  preferredDomains  String[]  @default([]) @map("preferred_domains")
  messageCount      Int       @default(0) @map("message_count")
  lastInteractionAt DateTime? @map("last_interaction_at")
  profileBuiltAt    DateTime? @map("profile_built_at")
  /// Versao do algoritmo de construcao. Incrementar forca rebuild.
  version           Int       @default(1)
  /// Preferencia de DETALHE detectada dos pedidos explicitos do usuario: "curto" | "detalhado".
  /// null = sem sinal suficiente (stand-by). Parametro deterministico do rastreador.
  verbosidade       String?   @map("verbosidade")
  /// Preferencia de FORMATO de resposta: "lista" | "tabela" | "texto". null = stand-by.
  formatoPreferido  String?   @map("formato_preferido")
  /// (DORMENTE, sem uso , revertido em 2026-06-21) coluna da antiga camada de resumo por IA.
  interactionPrompt String?   @map("interaction_prompt")
  /// Preferencias de APRESENTACAO (qual visao/breakdown), DEFAULTS, nunca filtros de recorte de
  /// dado. Ex.: {"faturamento":{"breakdownPreferido":"empresa"}}.
  presentationPrefs Json      @default("{}") @map("presentation_prefs")
  /// [{label, count, lastSeenAt}] , perguntas recorrentes; label = tema de vocabulario FECHADO.
  recurringQuestions Json     @default("[]") @map("recurring_questions")
  /// Modelo/rotina da ultima destilacao (auditoria). Ex.: "claude-profile-v1".
  lastLearnedModel  String?   @map("last_learned_model")
  /// Circuit-breaker (Onda 2): sinal de qualidade base antes do perfil ativo.
  qualityBaseline   Json?     @map("quality_baseline")
  profileAppliedAt  DateTime? @map("profile_applied_at")
  quarantinedAt     DateTime? @map("quarantined_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lastInteractionAt])
  @@map("user_agent_profiles")
}

/// Avaliacao automatica da qualidade de uma resposta do agente (Frente A).
/// Uma linha por `assistantMessageId`. Juiz default Gemini 2.5 Pro thinking via
/// OpenRouter (configuravel em AgentSettings.qualityJudgeModel).
model ConversationQualityEvaluation {
  id                 String   @id @default(uuid()) @db.Uuid
  conversationId     String   @map("conversation_id") @db.Uuid
  /// Nullable + sem @unique: pra FALHA_TECNICA (turno que nem gerou
  /// assistant message). Em rows normais, segue 1:1 com Message.
  assistantMessageId String?  @map("assistant_message_id") @db.Uuid
  judgeModel         String?  @map("judge_model")
  judgeVersion       String   @map("judge_version")
  razoes             String   @default("")
  flags              String[] @default([])
  toolsReexecuted    Json?    @map("tools_reexecuted")
  createdAt          DateTime @default(now()) @map("created_at")

  /// @deprecated escala 1-5 da versao antiga (4.914 rows historicas)
  aderencia             Int?
  /// @deprecated escala 1-5 da versao antiga
  correcaoFactual       Int?                         @map("correcao_factual")
  /// @deprecated escala 1-5 da versao antiga
  escolhaDeTools        Int?                         @map("escolha_de_tools")
  /// @deprecated escala 1-5 da versao antiga
  clareza               Int?
  /// @deprecated movido pra novo fluxo (PromptRecommendation)
  recomendacaoPrompt    String?                      @map("recomendacao_prompt")
  /// @deprecated pgvector embedding pra clusterizacao antiga
  recomendacaoEmbedding Unsupported("vector(1536)")? @map("recomendacao_embedding")

  /// Review humano opcional: super_admin pode sobrescrever status do judge
  /// via UI /agente/qualidade (drill-down "Ajustar manualmente").
  humanStatus     String?   @map("human_status")
  humanReviewedBy String?   @map("human_reviewed_by") @db.Uuid
  humanReviewedAt DateTime? @map("human_reviewed_at")

  /// Novo sistema /agente/qualidade. Status discreto + taxonomia de patterns.
  status           String   @default("PENDENTE")
  patterns         String[] @default([])
  /// Modelo do AGENTE que gerou a resposta (ex: gpt-5.4-nano).
  /// Permite filtrar KPI por modelo na UI.
  model            String?
  userMessageId    String?  @map("user_message_id") @db.Uuid
  /// Cap 4000 chars. Snapshot pra preservar contexto se Message for deletada.
  questionSnapshot String?  @map("question_snapshot")
  answerSnapshot   String?  @map("answer_snapshot")
  /// Chips de sugestao oferecidos ao usuario logo apos a resposta
  /// (bolinhas roxas da bubble). Snapshot do array final, ja apos
  /// extracao do canal [[suggestions]] / bullet-questions.
  suggestions      String[] @default([])
  /// Preenchido apenas em FALHA_TECNICA. Cap 1000 chars.
  technicalError   String?  @map("technical_error")

  /// AutoValidator (Onda 1.E): quantas vezes o validator disparou retry.
  /// 0 = passou de primeira; 1 = passou após retry corretivo.
  retryCount  Int     @default(0) @map("retry_count")
  /// V1|V2|V3|V4|null. Validador que disparou (null se aceito de primeira).
  retryReason String? @map("retry_reason")
  /// Detalhe categorizado, sem PII. Ex: "V2:numero_nao_derivado:moeda".
  retryDetail String? @map("retry_detail")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([status, createdAt])
  @@index([model, status])
  @@index([createdAt])
  @@index([humanStatus])
  @@index([aderencia])
  @@map("conversation_quality_evaluations")
}

/// Recomendacao de mudanca do prompt-mestre, agregada por cluster semantico das
/// `recomendacaoPrompt` dos `ConversationQualityEvaluation`. Revisao humana via UI
/// `/agente/inteligencia`. Aceitacao NAO automatiza mudanca de prompt — abre
/// caminho para PR manual no `identity-base.ts`.
model PromptRecommendation {
  id               String    @id @default(uuid()) @db.Uuid
  clusterKey       String    @unique @map("cluster_key")
  consolidatedText String    @map("consolidated_text")
  occurrences      Int       @default(1)
  /// pending | accepted | rejected | needs_more_review
  status           String    @default("pending")
  decidedAt        DateTime? @map("decided_at")
  decidedBy        String?   @map("decided_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@map("prompt_recommendations")
}

/// Telemetria de interacao com chips de sugestao. Usado para metricas e para
/// detectar dedup (action="dedup_dropped") e fallback (action="fallback_timeout").
/// TTL 90 dias via cron `agent-intelligence-cleanup` semanal.
model SuggestionInteraction {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  conversationId String?  @map("conversation_id") @db.Uuid
  chipText       String   @map("chip_text")
  /// welcome | contextual | bullet_extracted
  chipSource     String   @map("chip_source")
  /// impressed | clicked | dedup_dropped | fallback_timeout
  action         String
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([chipSource, createdAt])
  @@map("suggestion_interactions")
}

// ─── B3 — Financeiro / cobrança bancária (raws novos) ────────────────────────
// remessa/retorno(.item)/carteira já têm raw (ondas anteriores). Aqui só os
// raws novos: finan.cheque/finan.pix existem com 0 reg (estruturais, auto-ativam).
model RawFinanCheque {
  odooId        Int       @id @map("odoo_id")
  data          Json
  odooWriteDate DateTime? @map("odoo_write_date")
  syncedAt      DateTime  @default(now()) @map("synced_at")
  rawDeleted    Boolean   @default(false) @map("raw_deleted")

  @@index([odooWriteDate])
  @@index([rawDeleted])
  @@map("raw_finan_cheque")
}

