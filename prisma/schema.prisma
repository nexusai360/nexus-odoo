generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PlatformRole {
  super_admin
  admin
  manager
  viewer
}

enum Theme {
  dark
  light
  system
}

enum AuditAction {
  login_succeeded
  login_failed
  password_reset_requested
  password_reset_completed
  user_created
  user_updated
  user_deleted
  user_role_changed
  user_activated
  user_deactivated
  profile_updated
  profile_password_changed
  email_change_requested
  email_change_completed
  setting_updated
  session_revoked
  user_domains_changed
  // F5 — agente + WhatsApp + integrações
  user_whatsapp_added
  user_whatsapp_removed
  whatsapp_inbound_rejected
  agent_settings_updated
  llm_credential_created
  llm_credential_updated
  llm_credential_deleted
  api_key_created
  api_key_revoked
  whatsapp_channel_updated
  // RBAC v2 — recusa do Agente Nex por permissão de domínio (fast-path sem LLM).
  agent_permission_denied
  // Overhaul de auditoria (2026-06-18) — instrumentação ampla de eventos.
  logout
  api_key_updated
  api_key_rotated
  webhook_created
  webhook_updated
  webhook_secret_rotated
  webhook_toggled
  webhook_deleted
  external_mcp_server_created
  external_mcp_server_updated
  external_mcp_server_toggled
  external_mcp_server_deleted
  kb_document_created
  kb_document_deleted
  report_preset_created
  report_preset_deleted
  report_exported
}

// F5 — enums do agente e integrações
enum AgentChannel {
  whatsapp
  in_app
  playground
  // B2/raiz do dado: conversas geradas por replay/backtest/calibração de
  // qualidade (scripts quality-audit). Canal estrutural próprio para não
  // poluir o monitoramento Bubble (que mostra só conversa real in_app).
  backtest
}

enum MessageRole {
  user
  assistant
  tool
}

enum KbKind {
  PDF
  TXT
  URL
  MARKDOWN
  CSV
  XML
  YAML
  XLSX
  DOCX
  JSON
}

/// Estado de checkpoint de um recurso do agente (áudio, imagem, KB, documento).
/// OFF = desativado; PLAYGROUND = ativo só no playground; PRODUCTION = ativo em produção.
enum FeatureCheckpoint {
  OFF
  PLAYGROUND
  PRODUCTION
}

/// B1. Classificacao do usuario sobre uma resposta do agente (eixo do usuario,
/// distinto do EvalStatus do juiz).
enum UserFeedbackRating {
  CORRETO
  PARCIAL
  ERRADO
  ALUCINOU
}

/// B1. Tipo de evento no historico append-only de feedback.
enum MessageFeedbackAction {
  created
  rating_changed
  comment_set
  comment_edited
}

enum WhatsappResponseMode {
  direct
  n8n_webhook
}

enum WebhookDirection {
  inbound
  outbound
}

/// Eventos emissíveis em webhooks de saída (F5). Serializa para "agent.reply".
enum WebhookEvent {
  agent_reply
}

/// Nível mínimo de acesso de um canal do Agente Nex (F5). "off" = desativado;
/// os demais são roles de PlatformRole. Herança: role >= nível escolhido acessa.
enum ChannelAccessLevel {
  off
  viewer
  manager
  admin
  super_admin
}

enum ReportDomain {
  cadastros
  comercial
  contabil
  crm
  estoque
  financeiro
  fiscal
}

model User {
  id                     String                  @id @default(uuid()) @db.Uuid
  email                  String                  @unique
  password               String
  name                   String
  platformRole           PlatformRole            @default(viewer) @map("platform_role")
  isOwner                Boolean                 @default(false) @map("is_owner")
  isActive               Boolean                 @default(true) @map("is_active")
  mustChangePassword     Boolean                 @default(true) @map("must_change_password")
  passwordChangedAt      DateTime?               @map("password_changed_at")
  avatarUrl              String?                 @map("avatar_url")
  theme                  Theme                   @default(system)
  emailVerifiedAt        DateTime?               @map("email_verified_at")
  lastLoginAt            DateTime?               @map("last_login_at")
  lastActivityAt         DateTime?               @map("last_activity_at")
  lastLoginIp            String?                 @map("last_login_ip")
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  createdById            String?                 @map("created_by_id") @db.Uuid
  createdBy              User?                   @relation("UserCreator", fields: [createdById], references: [id])
  createdUsers           User[]                  @relation("UserCreator")
  audits                 AuditLog[]
  passwordResetTokens    PasswordResetToken[]
  emailChangeTokens      EmailChangeToken[]
  domainAccess           UserDomainAccess[]      @relation("UserDomainAccess")
  reportPresets          ReportPreset[]
  // F5
  conversations          Conversation[]
  whatsappNumbers        UserWhatsappNumber[]
  playgroundSessions     PlaygroundSession[]
  // F4.5 — Agente Nex Inteligencia
  agentProfile           UserAgentProfile?
  suggestionInteractions SuggestionInteraction[]
  messageFeedback        MessageFeedback[]

  @@index([platformRole, isActive])
  @@index([email])
  @@map("users")
}

/// Preset de configuração de visualização de um relatório (período + filtros).
/// Escopo: um preset pertence a um único usuário e a um único relatório do catálogo.
model ReportPreset {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reportId     String   @map("report_id")
  nome         String
  searchParams String   @map("search_params")
  favorito     Boolean  @default(false)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  @@index([userId, reportId])
  @@map("report_presets")
}

/// F6 , ficha de relatorio dinamico criada pelo Construtor de Relatorios (config-driven).
enum SavedReportTipo {
  tela_cheia
  widget
}

enum SavedReportStatus {
  rascunho
  publicado
}

model SavedReport {
  id                  String            @id @default(cuid())
  tipo                SavedReportTipo   @default(tela_cheia)
  titulo              String
  entry               Json
  schemaVersion       Int               @default(1) @map("schema_version")
  status              SavedReportStatus @default(rascunho)
  criadoPor           String            @map("criado_por") @db.Uuid
  visibilidadeConsumo String[]          @default([]) @map("visibilidade_consumo")
  etag                String            @default(cuid())
  criadoEm            DateTime          @default(now()) @map("criado_em")
  atualizadoEm        DateTime          @updatedAt @map("atualizado_em")

  @@index([criadoPor, status])
  @@map("saved_reports")
}

model AppSetting {
  key         String   @id
  value       Json
  description String?
  category    String
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedById String?  @map("updated_by_id") @db.Uuid

  @@map("app_settings")
}

/// Servidor MCP externo registrado para o Agente Nex consumir como cliente.
/// "Plugar MCPs" — agrega capacidades de terceiros (Slack, GitHub, etc.) ao Nex.
/// O `authToken` é persistido cifrado (AES-256-GCM via src/lib/encryption.ts).
model ExternalMcpServer {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  description String?
  transport   String    @default("http")
  url         String
  authHeader  String?   @map("auth_header")
  authToken   String?   @map("auth_token")
  enabled     Boolean   @default(true)
  lastStatus  String    @default("unknown") @map("last_status")
  lastCheckAt DateTime? @map("last_check_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  callLogs ExternalMcpCallLog[]

  @@index([enabled])
  @@map("external_mcp_servers")
}

/// Registro das chamadas que o Agente Nex faz a tools de servidores MCP
/// externos (Plugar MCP). Distinto do McpAuditLog, que e do nosso MCP interno.
/// `serverName` e denormalizado para o log sobreviver a exclusao do servidor.
model ExternalMcpCallLog {
  id           String             @id @default(uuid()) @db.Uuid
  serverId     String?            @map("server_id") @db.Uuid
  server       ExternalMcpServer? @relation(fields: [serverId], references: [id], onDelete: SetNull)
  serverName   String             @map("server_name")
  toolName     String             @map("tool_name")
  outcome      String
  durationMs   Int?               @map("duration_ms")
  errorMessage String?            @map("error_message")
  argsPreview  Json?              @map("args_preview")
  userId       String             @map("user_id") @db.Uuid
  criadoEm     DateTime           @default(now()) @map("criado_em")

  @@index([criadoEm])
  @@index([serverId])
  @@map("external_mcp_call_log")
}

/// Registro de que um usuário já viu o tour de uma tela. Usado para abrir o
/// tour automaticamente só na primeira visita, sobrevivendo a logout e troca
/// de conta (a marca fica por usuário, não no navegador).
model UserTourSeen {
  id      String   @id @default(uuid()) @db.Uuid
  userId  String   @map("user_id") @db.Uuid
  tourKey String   @map("tour_key")
  seenAt  DateTime @default(now()) @map("seen_at")

  @@unique([userId, tourKey])
  @@map("user_tour_seen")
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String?     @map("user_id") @db.Uuid
  user       User?       @relation(fields: [userId], references: [id])
  action     AuditAction
  targetType String?     @map("target_type")
  targetId   String?     @map("target_id")
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  details    Json?
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

/// Concessão de domínio de relatório a um usuário. super_admin/admin não têm
/// linhas (veem tudo); manager/viewer têm uma linha por domínio concedido.
model UserDomainAccess {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  domain      ReportDomain
  grantedById String?      @map("granted_by_id") @db.Uuid
  createdAt   DateTime     @default(now()) @map("created_at")
  user        User         @relation("UserDomainAccess", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, domain])
  @@index([userId])
  @@map("user_domain_access")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
