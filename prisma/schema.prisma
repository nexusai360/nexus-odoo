/// O3 (onda Pedido): histórico de transição de etapas do pedido. Fonte:
/// raw_pedido_documento_historico (pedido.documento.historico). 1 linha = 1
/// mudanca de etapa (etapa de destino). tempoEtapaDias = GREATEST(tempo_etapa,0)
/// (o campo nativo do Odoo tem ~204 valores negativos, saneados no builder).
/// Permite "tempo em cada etapa" e "pedidos travados no fluxo (processo)".
model FatoPedidoHistorico {
  odooId         Int       @id @map("odoo_id")
  pedidoId       Int?      @map("pedido_id")
  etapaId        Int?      @map("etapa_id")
  etapaNome      String?   @map("etapa_nome")
  etapaTipo      String?   @map("etapa_tipo")
  dataEntrada    DateTime? @map("data_entrada")
  dataProxima    DateTime? @map("data_proxima")
  tempoEtapaDias Int       @default(0) @map("tempo_etapa_dias")
  usuarioId      Int?      @map("usuario_id")
  criadoEm       DateTime? @map("criado_em")
  atualizadoEm   DateTime  @default(now()) @map("atualizado_em")

  @@index([pedidoId])
  @@index([etapaId])
  @@index([dataEntrada])
  @@map("fato_pedido_historico")
}

