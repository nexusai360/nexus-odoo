/// R5.01 (Ronda 5): empresas do grupo Matrix Fitness Group (matriz/filial)
/// extraidas de raw_res_company. Permite responder "quantas filiais temos",
/// "quais empresas estao em SP", etc.
model DimEmpresaGrupo {
  odooId       Int      @id @map("odoo_id")
  nome         String
  cnpj         String?
  tipo         String // 'matriz' | 'filial'
  uf           String?
  ativo        Boolean  @default(true)
  atualizadoEm DateTime @default(now()) @map("atualizado_em")

  @@index([tipo])
  @@index([uf])
  @@map("dim_empresa_grupo")
}

/// De-para CNPJ-raiz -> regime tributario da empresa (Fase 5). Fonte:
/// sped.empresa.regime_tributario (store=false, lido por leitura direcionada no
/// builder dim-empresa-regime). Chave = raiz do CNPJ (8 digitos): o regime e
/// opcao da pessoa juridica, filiais herdam. 1 raiz -> 1 regime (assert no builder).
model DimEmpresaRegime {
  cnpjRaiz     String   @id @map("cnpj_raiz")
  regimeCodigo String   @map("regime_codigo")
  regimeLabel  String   @map("regime_label")
  atualizadoEm DateTime @default(now()) @map("atualizado_em")

  @@map("dim_empresa_regime")
}

model FatoParceiro {
  odooId       Int       @id @map("odoo_id")
  nome         String?
  nomeCompleto String?   @map("nome_completo")
  documento    String?
  /// F2 (entidades): documento so com digitos (CNPJ/CPF sem mascara nem prefixo BR-).
  /// Preenchido pelo builder (mapParceiroRow) e backfill; string vazia normalizada para null.
  /// Indexado: ramo documento de resolverParceiro filtra por igualdade aqui (spec 3.4).
  documentoDigits String? @map("documento_digits")
  ehCliente    Boolean   @default(false) @map("eh_cliente")
  ehFornecedor Boolean   @default(false) @map("eh_fornecedor")
  ehEmpresa    Boolean   @default(false) @map("eh_empresa")
  cidade       String?
  uf           String?
  pais         String?
  cep          String?
  email        String?
  telefone     String?
  ativo        Boolean   @default(true)
  /// T-42 (Ronda 4): data de criacao do parceiro no Odoo (campo create_date).
  /// Populada a partir de raw_res_partner.data->>'create_date'. Permite filtrar
  /// "parceiros novos cadastrados esta semana/mes" via tool dedicada.
  dataCriacao  DateTime? @map("data_criacao") @db.Timestamp(3)
  atualizadoEm DateTime  @default(now()) @map("atualizado_em")

  @@index([uf])
  @@index([ehCliente])
  @@index([ehFornecedor])
  @@index([dataCriacao])
  @@index([documentoDigits])
  @@map("fato_parceiro")
}

/// Catalogo canonico de produtos (todos os 3787 de raw_sped_produto).
