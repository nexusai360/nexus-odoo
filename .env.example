# =====================================================
# nexus-odoo — Variáveis de ambiente (TEMPLATE)
#
# Este arquivo VAI para o GitHub. NÃO coloque valores reais aqui.
# Copie para:
#   .env.local       → desenvolvimento local   (NÃO commitado)
#   .env.production  → produção                (NÃO commitado, fica só local + Portainer)
#
# Variáveis crescem a cada fase do projeto. Hoje constam apenas
# as conhecidas nas fases F0–F2.
# =====================================================

# ---- Odoo Tauga — acesso via API XML-RPC (read-only do nosso lado) ----
# A senha REAL nunca entra aqui nem no chat — só no .env.local
ODOO_URL="https://grupojht.tauga.online"
ODOO_DB="grupojht"
ODOO_USERNAME="suporte"
ODOO_PASSWORD="definir-no-env-local"

# ---- Banco interno do nexus-odoo (o cache) ----
DATABASE_URL="postgresql://nexus:${DB_PASSWORD}@db:5432/nexus_odoo?schema=public"
DB_PASSWORD="gerar-com-openssl-rand-base64-24"

# ---- Redis (fila BullMQ + pub/sub) ----
REDIS_URL="redis://redis:6379"

# ---- Auth (NextAuth v5) — gerar valores únicos para produção ----
NEXTAUTH_SECRET="gerar-com-openssl-rand-base64-32"
NEXTAUTH_URL="https://nexus-odoo.SEU-DOMINIO.com"

# ---- Encryption — AES-256 (32 bytes hex = 64 chars) ----
ENCRYPTION_KEY="gerar-com-openssl-rand-hex-32"

# ---- Owner inicial (seed do primeiro usuário) ----
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="definir-no-env-local"
ADMIN_NAME="Administrador"

# ---- App ----
# NÃO definir NODE_ENV aqui. O Next.js o define sozinho (`development` em
# `next dev`, `production` em `next build`/`next start`). Forçá-lo a
# "development" faz o `next build` prerenderizar com o React de
# desenvolvimento e quebra o build de produção (TypeError useContext null).
APP_VERSION="dev"

# ---- MCP semântico (F4) ----
# Service token: segredo forte estático; o agente F5 o envia em Authorization: Bearer.
MCP_SERVICE_TOKEN=
# Senha do role Postgres nexus_mcp (GRANT mínimo). Obrigatória — gerar com: openssl rand -base64 24
MCP_DB_PASSWORD=
# URL Postgres do role nexus_mcp — OBRIGATÓRIA. Sem ela o servidor MCP não inicia (MEN-5).
# Em dev: pode apontar para o role principal enquanto o nexus_mcp não estiver provisionado.
# Em produção: DEVE usar o role nexus_mcp com GRANT mínimo (camada 4 do RBAC).
# O docker-compose monta a URL usando ${MCP_DB_PASSWORD}.
MCP_DATABASE_URL=

# Caminho 3c (modo BI) — URL Postgres do role read-only nexus_mcp_bi.
# Ausente: o modo BI fica indisponível (bi_consulta_avancada responde erro
# estruturado), mas o MCP sobe normalmente (fail-safe).
MCP_BI_DATABASE_URL=

# ---- Agente de IA — F5 ----
# URL do servidor MCP da F4 (Streamable HTTP). O agente usa para chamar as tools semânticas.
# Em dev: http://localhost:3001/mcp | Em produção: http://mcp:3001/mcp (nome do container)
MCP_URL=

# Token de autenticação server-to-server (agente → MCP). Deve coincidir com MCP_SERVICE_TOKEN acima.
# Gerar com: openssl rand -base64 32
# MCP_SERVICE_TOKEN já definido na seção F4 acima — não duplicar aqui.

# Segredo HMAC para verificar autenticidade do webhook inbound do WhatsApp (n8n → plataforma).
# Gerar com: openssl rand -base64 32
WHATSAPP_INBOUND_SECRET=

# =====================================================
# F4 Onda 2 — Capacidade de escrita no servidor MCP
# =====================================================

# Odoo escrita (separado da leitura). Durante a Onda 0 + validação, aponta para
# a base de teste. Cutover para produção é decisão humana, depois de validado.
# Se vazio, fallback para ODOO_URL/DB/USERNAME/PASSWORD (read).
ODOO_WRITE_URL="https://grupojht.teste.tauga.online"
ODOO_WRITE_DB="grupojht_teste"
ODOO_WRITE_USER=
ODOO_WRITE_PASSWORD=
ODOO_WRITE_TIMEOUT_MS=30000

# Audit log — retenção configurável
MCP_AUDIT_DETAIL_RETENTION_DAYS=90
MCP_AUDIT_FULL_RETENTION_DAYS=730
MCP_IDEMPOTENCY_TTL_HOURS=24

# Tokens de acesso externo ao MCP
MCP_TOKEN_PREFIX=mcp_live_
MCP_TOKEN_ENTROPY_BYTES=32

# Rate limit por chave externa (sliding window 60s)
MCP_EXTERNAL_RATE_LIMIT_DEFAULT=60
MCP_EXTERNAL_RATE_LIMIT_MAX=600

# Cache LRU de ApiKeys (lookup de auth)
MCP_KEY_CACHE_TTL_SEC=60
MCP_KEY_CACHE_MAX_SIZE=1000

# Kill switch (Plan v3 Task Q-rollback): "false" desabilita TODAS as
# WriteToolEntry retornando 503 feature_disabled. Default em produção: false.
# Ativar manualmente após validação humana.
MCP_WRITE_ENABLED=false

# Modo shadow (Plan v3 Task Q-cutover-shadow): janela em que header
# X-MCP-Shadow-Run: true força execução contra ODOO_WRITE_URL (teste)
# mesmo após cutover de produção. Vazio = sem janela.
MCP_CUTOVER_END_AT=

# Logging operacional (pino)
LOG_LEVEL=info

# ─── R1 router de catalogo (Sub-projeto do roadmap de cobertura completa) ───
# Kill-switch nivel 3 (ultimo recurso, ver SPEC v3 §16.3).
# Quando "true", forca o router de catalogo em modo SHADOW independente do
# que estiver setado em AgentSettings.router_enabled. Use apenas quando o
# painel admin estiver inacessivel e o nivel 2 (POST /api/admin/router/kill)
# tambem nao puder ser executado. Requer redeploy do container `app` para
# voltar a permitir ativacao via painel.
ROUTER_FORCE_DISABLE=false
