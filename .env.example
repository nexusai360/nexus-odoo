# =====================================================
# nexus-odoo — Variáveis de ambiente (TEMPLATE)
#
# Este arquivo VAI para o GitHub. NÃO coloque valores reais aqui.
# Copie para:
#   .env.local       → desenvolvimento local   (NÃO commitado)
#   .env.production  → produção                (NÃO commitado, fica só local + Portainer)
#
# Variáveis crescem a cada fase do projeto. Hoje constam apenas
# as conhecidas nas fases F0–F2.
# =====================================================

# ---- Odoo Tauga — acesso via API XML-RPC (read-only do nosso lado) ----
# A senha REAL nunca entra aqui nem no chat — só no .env.local
ODOO_URL="https://grupojht.tauga.online"
ODOO_DB="grupojht"
ODOO_USERNAME="suporte"
ODOO_PASSWORD="definir-no-env-local"

# ---- Banco interno do nexus-odoo (o cache) ----
DATABASE_URL="postgresql://nexus:${DB_PASSWORD}@db:5432/nexus_odoo?schema=public"
DB_PASSWORD="gerar-com-openssl-rand-base64-24"

# ---- Redis (fila BullMQ + pub/sub) ----
REDIS_URL="redis://redis:6379"

# ---- Auth (NextAuth v5) — gerar valores únicos para produção ----
NEXTAUTH_SECRET="gerar-com-openssl-rand-base64-32"
NEXTAUTH_URL="https://nexus-odoo.SEU-DOMINIO.com"

# ---- Encryption — AES-256 (32 bytes hex = 64 chars) ----
ENCRYPTION_KEY="gerar-com-openssl-rand-hex-32"

# ---- Owner inicial (seed do primeiro usuário) ----
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="definir-no-env-local"
ADMIN_NAME="Administrador"

# ---- App ----
NODE_ENV="development"
APP_VERSION="dev"
