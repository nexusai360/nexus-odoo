# .env.test.example
# Variáveis de ambiente para os testes E2E do Bloco P (F4 Onda 2).
# Copiar para .env.test e preencher antes de rodar os testes E2E que tocam
# Odoo real ou DB local.
#
# .env.test NÃO vai para o git (coberto por .gitignore via ".env.*").
# Apenas este .env.test.example é versionado.
#
# Testes que NÃO precisam de Odoo real (capability, idempotency, rate limit,
# validação Zod) rodam com qualquer DATABASE_URL local + Redis local.
# Testes que tocam Odoo real são skipped automaticamente se
# ODOO_WRITE_USER / ODOO_WRITE_PASSWORD estiverem ausentes.

# ─── Banco de dados local (obrigatório para todos os E2E) ────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nexus_odoo_test

# ─── Redis local (obrigatório para testes de rate limit / idempotency) ───────
REDIS_URL=redis://localhost:6379

# ─── Habilitar operações de escrita no MCP ───────────────────────────────────
MCP_WRITE_ENABLED=true

# ─── Credenciais do Odoo de teste (opcional, skip elegante se ausentes) ─────
# Aponta para a instância de TESTE, nunca para produção. O canal de escrita
# NÃO faz fallback para ODOO_* (produção): se faltar qualquer ODOO_WRITE_*, o
# clientFromEnv("write") lança erro.
# ODOO_WRITE_URL=https://grupojht.teste.tauga.online
# ODOO_WRITE_DB=teste_grupojht
# ODOO_WRITE_USER=seu_usuario_de_teste
# ODOO_WRITE_PASSWORD=sua_senha_de_teste
