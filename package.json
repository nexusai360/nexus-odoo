{
  "name": "nexus-odoo",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma de dados do ERP Odoo da Matrix Fitness Group, dashboard e MCP",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && NODE_ENV=production next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "db:provision": "psql \"$DATABASE_URL\" -v mcp_pw=\"$MCP_DB_PASSWORD\" -v bi_pw=\"$MCP_BI_DB_PASSWORD\" -f prisma/sql/provision-mcp.sql",
    "db:deploy": "prisma migrate deploy && npm run db:provision",
    "worker": "tsx --env-file=.env.local src/worker/index.ts",
    "mcp": "tsx --env-file=.env.local mcp/index.ts",
    "gen:mcp-catalog": "tsx scripts/gen-mcp-catalog-snapshot.ts",
    "audit:tools": "tsx scripts/audit-mcp-tools.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.73.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "framer-motion": "^11.18.2",
    "ioredis": "^5.10.1",
    "json-stable-stringify": "^1.3.0",
    "lru-cache": "^11.5.0",
    "lucide-react": "^1.7.0",
    "nanoid": "^5.1.7",
    "next": "16.2.2",
    "next-auth": "^5.0.0-beta.30",
    "pdf-parse": "^1.1.4",
    "pg": "^8.20.0",
    "pgsql-parser": "^17.9.15",
    "pino": "^10.3.1",
    "prisma": "^7.6.0",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/json-stable-stringify": "^1.1.0",
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "ioredis-mock": "^8.13.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-mock-extended": "^4.0.0",
    "pino-pretty": "^13.1.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
